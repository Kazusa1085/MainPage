---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Profile from '../components/Profile.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import Terminal from '../components/Terminal.astro';
import RSS from '../components/RSS.astro';
import Projects from '../components/Projects.astro';
import Links from '../components/Links.astro';
import Notice from '../components/Notice.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Navbar />

  <main class="container">
    <!-- Skeleton Screen -->
    <div class="profile skeleton-container" id="skeleton-screen" role="status" aria-label="Loading content" aria-live="polite">
      <span class="sr-only">正在加载页面内容，请稍候...</span>
      <div class="skeleton-avatar skeleton"></div>
      <div class="skeleton-name skeleton"></div>
      <div class="skeleton-tagline skeleton"></div>
      <div class="skeleton-music skeleton"></div>
      <div class="skeleton-terminal skeleton"></div>
      <div class="skeleton-divider skeleton"></div>
      <div class="skeleton-footer skeleton"></div>
    </div>

    <!-- Actual Content -->
    <div class="profile content-initial-hidden" id="actual-content" aria-busy="true">
      <Profile />
      <MusicPlayer />
      <Terminal />
      <RSS />
      <Projects />
      <Links />
      <Notice />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
// Skeleton screen: show content after a delay
const skeleton = document.getElementById('skeleton-screen');
const content = document.getElementById('actual-content');

// Fade in content after skeleton delay
const fadeInDelay = 1000; // matches animation config
setTimeout(() => {
  if (skeleton) skeleton.style.opacity = '0';
  if (content) {
    content.classList.remove('content-initial-hidden');
    content.classList.add('content-visible');
    content.setAttribute('aria-busy', 'false');
  }
  // Remove skeleton from DOM after transition
  setTimeout(() => skeleton?.remove(), 300);
}, fadeInDelay);

// ===== 滚动渐显 (lazy-load)：Terminal / RSS / Links 等区块滚入视口时淡入 =====
const lazyElements = document.querySelectorAll('.lazy-load');
if (lazyElements.length > 0) {
  if (!('IntersectionObserver' in window)) {
    lazyElements.forEach((el) => el.classList.add('visible'));
  } else {
    const lazyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            lazyObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    lazyElements.forEach((el) => lazyObserver.observe(el));
  }
}
</script>

<style>
  .skeleton-music { width: 100%; height: 34px; margin: 24px 0 40px; border-radius: 4px; }
  .skeleton { background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--border) 50%, var(--bg-secondary) 75%); background-size: 200% 100%; animation: skeleton-loading 1.5s ease-in-out infinite; }
  .skeleton-container { transition: opacity 0.3s ease; }
  #actual-content { position: relative; z-index: 5; }
</style>
