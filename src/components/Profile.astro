---
import { profile } from '../data/config.js';
---
<div class="avatar-wrapper">
  <div class="avatar">
    <img src={profile.avatar} alt={`${profile.name} Avatar`} width="140" height="140" loading="eager" />
  </div>
  <div class="status" aria-hidden="true"></div>
</div>

<h1 class="name" id="profile-name">{profile.name}</h1>

<p class="tagline">
  <span>{profile.tagline.prefix}</span>
  <span class="highlight">{profile.tagline.highlight}</span>
</p>